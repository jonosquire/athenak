# AthenaK input: spherical-shell FV divergence diagnostic on a LOG-R grid.
# Same operator/cases as sph_shell_divergence.athinput (F_r=r^n, F_th=sin theta,
# F_ph=sin(m phi)); radial faces are uniform in ln(r). Expected O(h^2)
# convergence for smooth integrands.
# Build with -DPROBLEM=sph_shell_hydro.

<comment>
problem   = sph_shell_hydro / divergence_test (log-r)

<job>
basename  = SphShellDivLogR

<mesh>
nghost    = 2
nx1       = 64
x1min     = 1.0
x1max     = 10.0
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 32
x2min     = 0.7853981633974483
x2max     = 2.356194490192345
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 16
x3min     = 0.0
x3max     = 1.5707963267948966
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 32
nx3       = 16

<coord>
system          = spherical_shell
verify_geometry = false

<spherical_shell>
radial_grid = log

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 0
tlim       = 1.0

<hydro>
eos             = ideal
reconstruct     = plm
rsolver         = hllc
gamma           = 1.6666666666666667

<problem>
mode      = divergence_test
rho0      = 1.0
p0        = 1.0
div_n_exp = 3
div_m_phi = 2
