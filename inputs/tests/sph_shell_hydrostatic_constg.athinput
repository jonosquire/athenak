# AthenaK input: isothermal hydrostatic atmosphere in constant radial gravity.
# Analytic IC:
#   rho(r) = rho0 * exp(-(r - r_ref) / H_p),   p = rho * c_s^2,
#   H_p    = c_s^2 / g0
# Background: rho0=1, p0=1 so c_s_iso=1; g0=0.5 so H_p=2.0 (gentle stratification).
# Domain: r in [1,3] (one scale height), thin theta/phi wedge.
# Hydro evolves adiabatically (gamma=5/3); the isothermal IC is NOT an
# adiabatic equilibrium, so v will grow slowly. Diagnostic prints max|v|/cs.
# The radial gravity uses AthenaK's <hydro_srcterms>/const_accel feature with
# const_accel_dir=1 (x1=r) and const_accel_val=-g0 (negative ~ inward).
# Build with -DPROBLEM=sph_shell_hydro.

<comment>
problem   = sph_shell_hydro / hydrostatic_constg

<job>
basename  = SphShellHSEconst

<mesh>
nghost    = 2
nx1       = 64
x1min     = 1.0
x1max     = 3.0
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 8
x2min     = 1.4707963267948966
x2max     = 1.6707963267948966
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 8
x3min     = 0.0
x3max     = 0.2
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 8
nx3       = 8

<coord>
system          = spherical_shell
verify_geometry = false

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = -1
tlim       = 0.5

<hydro>
eos             = ideal
reconstruct     = plm
rsolver         = hllc
gamma           = 1.6666666666666667

<hydro_srcterms>
const_accel     = true
const_accel_val = -0.5     # g_r = -g0
const_accel_dir = 1

<output1>
file_type   = vtk
variable    = hydro_w
dt          = 0.1
ghost_zones = false

<problem>
mode  = hydrostatic_constg
rho0  = 1.0
p0    = 1.0
g0    = 0.5
r_ref = 1.0
