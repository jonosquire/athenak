# AthenaK input: spherical-shell MHD toroidal-field divergence check.
# IC: rho=const, p=const, v=0, B_phi(r,theta) = B0 * sin(theta) / r, B_r=B_t=0.
# Divergence-free for any axisymmetric B_phi(r, theta). NOT a force balance --
# magnetic tension drives radial motion. Use as a short-time vibe check for
# the CT preservation of divB and as a sanity test for the MHD source terms.
# Build with -DPROBLEM=sph_shell_mhd.

<comment>
problem   = sph_shell_mhd / toroidal_static

<job>
basename  = SphShellMHDToroidal

<mesh>
nghost    = 2

nx1       = 64
x1min     = 1.0
x1max     = 3.0
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 32
x2min     = 0.5235987755982988
x2max     = 2.617993877991494
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 16
x3min     = 0.0
x3max     = 1.5707963267948966
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 32
nx3       = 16

<coord>
system          = spherical_shell

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 10
tlim       = 100.0

<mhd>
eos             = ideal
reconstruct     = plm
rsolver         = hlld
gamma           = 1.6666666666666667

<problem>
mode  = toroidal_static
rho0  = 1.0
p0    = 1.0
B0    = 0.1                       # weak field, so initial acceleration stays small
