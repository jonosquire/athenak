# AthenaK input: spherical-shell geometry sanity on a POWER-LAW radial grid.
# r_face = r_min + (r_max - r_min) * xi_norm^alpha,  xi_norm in [0, 1].
# Cell volume should still match the analytic wedge to roundoff regardless of
# alpha (volume is derived from face positions only).
# Build with -DPROBLEM=sph_shell_hydro.

<comment>
problem   = sph_shell_geom power-law

<job>
basename  = SphShellGeomPow

<mesh>
nghost    = 2
nx1       = 64
x1min     = 1.0
x1max     = 5.0
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 16
x2min     = 0.39269908169872414
x2max     = 2.748893571891069
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 16
x3min     = 0.0
x3max     = 1.5707963267948966
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 64
nx2       = 16
nx3       = 16

<coord>
system    = spherical_shell

<spherical_shell>
radial_grid  = power_law
r_grid_alpha = 2.0          # quadratic stretching toward r_max

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 0
tlim       = 1.0

<hydro>
eos             = ideal
reconstruct     = plm
rsolver         = hllc
gamma           = 1.6666666666666667

<problem>
mode  = uniform
rho0  = 1.0
p0    = 1.0
