# AthenaK input: spherical-shell hydro smoke / CFL theta-dependence test.
# Same uniform setup as the preservation test but evolves a couple of cycles
# at two different theta wedges. With the spherical CFL using
# ds3 = r * sin(theta) * dphi, the timestep should be smaller for a wedge
# closer to the pole (smaller sin theta) than for a wedge near the equator.
# Run with two different x2min/x2max overrides to compare.
# Build with -DPROBLEM=sph_shell_hydro.

<comment>
problem   = sph_shell_hydro / smoke

<job>
basename  = SphShellSmoke

<mesh>
nghost    = 2

nx1       = 16
x1min     = 1.0
x1max     = 2.0
ix1_bc    = outflow
ox1_bc    = outflow

nx2       = 16
x2min     = 1.4707963267948966   # pi/2 - 0.1  (equatorial)
x2max     = 1.6707963267948966   # pi/2 + 0.1
ix2_bc    = outflow
ox2_bc    = outflow

nx3       = 16
x3min     = 0.0
x3max     = 0.7853981633974483   # pi/4
ix3_bc    = periodic
ox3_bc    = periodic

<meshblock>
nx1       = 16
nx2       = 16
nx3       = 16

<coord>
system    = spherical_shell

<time>
evolution  = dynamic
integrator = rk2
cfl_number = 0.3
nlim       = 5
tlim       = 1.0

<hydro>
eos             = ideal
reconstruct     = plm
rsolver         = hllc
gamma           = 1.6666666666666667

<problem>
mode = uniform
rho0 = 1.0
p0   = 1.0
